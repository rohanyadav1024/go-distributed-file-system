DFS_REPLICATION_FACTOR=3
DFS_METADATA_DB_PATH=./data/metad/metad.db
DFS_METADATA_ADDR=:50051
DFS_METRICS_ADDR=:9090
DFS_JWT_SECRET=change-me
DFS_FAILURE_TIMEOUT_SECONDS=15
DFS_MONITOR_INTERVAL_SECONDS=5
DFS_DEFAULT_CHUNK_SIZE_MB=4
DFS_ALLOWED_CHUNK_SIZE_MIN_MB=1
DFS_ALLOWED_CHUNK_SIZE_MAX_MB=16
DFS_MAX_FILE_SIZE_MB=512
DFS_MAX_CHUNKS_PER_FILE=128
DFS_MAX_CHUNKS_PER_NODE=100000
DFS_HEADER_SIZE_BYTES=40
DFS_CONCURRENT_WRITES=32
DFS_WRITE_FSYNC_MODE=per_chunk
DFS_INTEGRITY_ALGO=sha256
DFS_STORAGE_LAYOUT=2_char_sharding
